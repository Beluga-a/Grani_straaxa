# ── Основное ──────────────────────────────────────────────────
ADMIN_SECRET=придумай_длинную_случайную_строку

# Публичный URL сайта (для OAuth callback-ов)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Google OAuth ───────────────────────────────────────────────
# 1. Зайди на https://console.cloud.google.com/
# 2. Создай проект → APIs & Services → Credentials → OAuth 2.0 Client ID
# 3. Тип: Web application
# 4. Authorized redirect URIs: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# ── VK OAuth ──────────────────────────────────────────────────
# 1. Зайди на https://vk.com/apps?act=manage
# 2. Создай приложение → Веб-сайт
# 3. Authorized redirect URI: http://localhost:3000/api/auth/vk/callback
VK_APP_ID=12345678
VK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Telegram Login Widget ──────────────────────────────────────
# 1. Создай бота через @BotFather в Telegram
# 2. /newbot → получи токен
# 3. /setdomain → укажи домен сайта (для localhost нужен ngrok/tunnel)
TG_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
NEXT_PUBLIC_TG_BOT_NAME=YourBotName_bot
